CREATE TABLE clientes (
    id INT PRIMARY KEY AUTO_INCREMENT,
    correo VARCHAR(100) NOT NULL UNIQUE,
    nombre VARCHAR(100) NOT NULL,
    apellidos VARCHAR(100) NOT NULL,
    password VARCHAR(255) NOT NULL,
    tipo_documento VARCHAR(20) NOT NULL,
    numero_documento VARCHAR(20) NOT NULL UNIQUE,
    celular VARCHAR(20)
);

CREATE TABLE reclamos (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,
    tipo_documento VARCHAR(50),
    numero_documento VARCHAR(50),
    primer_nombre VARCHAR(100),
    segundo_nombre VARCHAR(100),
    primer_apellido VARCHAR(100),
    segundo_apellido VARCHAR(100),
    correo VARCHAR(100),
    telefono VARCHAR(20),
    direccion VARCHAR(255),
    departamento VARCHAR(100),
    provincia VARCHAR(100),
    distrito VARCHAR(100),
    servicio_contratado VARCHAR(255),
    numero_orden VARCHAR(50),
    identificacion_servicio VARCHAR(50),
    monto_reclamado DECIMAL(10,2),
    tipo_reclamo VARCHAR(50),
    motivo TEXT,
    detalle_solicitud TEXT,
    pedido_concreto TEXT,
    acepto_politicas BOOLEAN DEFAULT TRUE
);

CREATE TABLE areas (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,
    nombre VARCHAR(100) UNIQUE,
    descripcion TEXT,
    entregables TEXT,
    proceso_trabajo TEXT
);

CREATE TABLE proyectos (
    id BIGINT PRIMARY KEY AUTO_INCREMENT,
    nombre VARCHAR(255),
    descripcion TEXT,
    ubicacion VARCHAR(255),
    estado ENUM('En ejecución', 'Finalizado', 'Planificado', 'Cancelado'),
    costo DECIMAL(10,2),
    avance TINYINT UNSIGNED,
    clientes_id INT,
    areas_id BIGINT,
    CONSTRAINT fk_proyecto_cliente FOREIGN KEY (clientes_id) REFERENCES clientes(id),
    CONSTRAINT fk_proyecto_area FOREIGN KEY (areas_id) REFERENCES areas(id)
);